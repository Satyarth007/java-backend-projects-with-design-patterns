<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="carSpecification" class="org.example.dependencyInjection.constructorInjection.Specification">
        <property name="make" value="Lamborghini"> </property>
        <property name="model" value="Aventador"> </property>
    </bean>

    <bean id="myCar" class="org.example.dependencyInjection.constructorInjection.Car">
        <constructor-arg ref="carSpecification"/>
    </bean>

</beans>