<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="specification1" class="org.example.autowire.type.Specification">
        <property name="make" value="Mercedes"> </property>
        <property name="model" value="AMG GT"> </property>
    </bean>

    <bean id="myCar" class="org.example.autowire.type.Car" autowire="byType" />


</beans>