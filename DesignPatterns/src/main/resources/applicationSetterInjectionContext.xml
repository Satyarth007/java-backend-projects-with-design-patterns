<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="carSpecification" class="org.example.dependencyInjection.setterInjection.Specification">
        <property name="make" value="Porsche"> </property>
        <property name="model" value="911 GT"> </property>
    </bean>

    <bean id="myCar" class="org.example.dependencyInjection.setterInjection.Car">
        <property name="specification" ref="carSpecification"/>
    </bean>

</beans>